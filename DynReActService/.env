## Profile Selection - OSS Version
## For using standard OSS (non-RAS) components
DYNREACT_PROFILE=oss
DYNREACT_ENERGY=./data/energy_context.json

## Configuration Providers - OSS defaults
CONFIG_PROVIDER=default+file:./data/site.json
SNAPSHOT_PROVIDER=default+file:./data/snapshots
SHORT_TERM_PLANNING_PARAMS=default+file:./data/stp_context.json

## Cost Provider (optional for OSS)
COST_PROVIDER=

## General Settings
PYTHONUNBUFFERED=1
